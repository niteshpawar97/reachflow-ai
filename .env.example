# ReachFlow AI — environment template. Copy to .env and fill in. Safe to commit (no real secrets).
NODE_ENV=development

# Database (PostgreSQL / Neon)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# API
API_PORT=3000
API_PREFIX=api
# Publicly reachable API base URL — used to build email open/click tracking
# links. In production set this to your real domain (e.g. https://app.you.com/api).
APP_PUBLIC_URL=http://localhost:3000/api

# Auth
JWT_ACCESS_SECRET=change_me
JWT_REFRESH_SECRET=change_me
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600

# Redis (BullMQ) — optional; the campaign sender uses the DB as its queue and
# does NOT require Redis. Set this only when moving to the dedicated BullMQ worker.
REDIS_URL=redis://localhost:6379

# Campaign auto-send: when true, the API sends due campaign emails on a timer
# (no Redis needed). Leave false in dev if you don't want it firing.
ENABLE_SEND_SCHEDULER=false
SEND_SCHEDULER_INTERVAL_MS=30000

# Mailbox secret encryption (AES-256-GCM). Any passphrase; keep it stable &
# secret — rotating it makes existing stored mailbox credentials undecryptable.
MAILBOX_ENCRYPTION_KEY=change_me_to_a_long_random_string

# AI provider — swap without code changes. one of: gemini | claude | none
AI_PROVIDER=none
# Google Gemini (free tier: https://aistudio.google.com -> Get API key)
GEMINI_API_KEY=
# Anthropic Claude (pay-as-you-go: https://console.anthropic.com -> API Keys)
ANTHROPIC_API_KEY=
# Optional per-tier model overrides (defaults are sensible):
# Gemini defaults to gemini-flash-latest on all tiers (works on the free tier).
# Once you have paid quota, point deep at the pro model:
# GEMINI_MODEL_DEEP=gemini-pro-latest
# CLAUDE_MODEL_FAST=claude-haiku-4-5
# CLAUDE_MODEL_DEEP=claude-opus-4-8

# Web
WEB_PORT=5173
VITE_API_URL=http://localhost:3000/api
