// ReachFlow AI — Prisma schema.
// Conventions (see docs/05-database.md): uuid PKs, snake_case columns/tables via @map,
// timestamptz timestamps, soft-delete via deleted_at, workspace_id tenancy seam on domain tables.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Global platform role (across the whole app).
enum UserRole {
  ADMIN
  STAFF
  CLIENT
}

// Role within a specific workspace (tenant).
enum WorkspaceRole {
  ADMIN
  STAFF
  CLIENT
}

model User {
  id              String    @id @default(uuid()) @db.Uuid
  email           String    @unique
  passwordHash    String?   @map("password_hash")
  name            String?
  avatarUrl       String?   @map("avatar_url")
  emailVerifiedAt DateTime? @map("email_verified_at") @db.Timestamptz(6)
  roleGlobal      UserRole  @default(CLIENT) @map("role_global")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz(6)

  ownedWorkspaces Workspace[]       @relation("WorkspaceOwner")
  memberships     WorkspaceMember[]
  sessions        Session[]

  @@index([deletedAt])
  @@map("users")
}

// Refresh-token sessions. The raw refresh token is never stored — only its hash.
// Rotation: on refresh the current session is revoked and a new one created.
model Session {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  refreshTokenHash String    @unique @map("refresh_token_hash")
  userAgent        String?   @map("user_agent")
  ip               String?
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Workspace {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  slug        String    @unique
  ownerUserId String    @map("owner_user_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  owner     User               @relation("WorkspaceOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  members       WorkspaceMember[]
  settings      WorkspaceSettings?
  companies     Company[]
  contacts      Contact[]
  leads         Lead[]
  websiteAudits      WebsiteAudit[]
  leadScores         LeadScore[]
  emailVerifications EmailVerification[]
  emailDrafts        EmailDraft[]

  @@index([ownerUserId])
  @@index([deletedAt])
  @@map("workspaces")
}

// 1:1 settings for a workspace. JSONB blobs hold evolving config so we don't
// churn the schema (sending windows, from-identity, compliance identity).
model WorkspaceSettings {
  id             String   @id @default(uuid()) @db.Uuid
  workspaceId    String   @unique @map("workspace_id") @db.Uuid
  timezone       String   @default("UTC")
  sendingWindows Json?    @map("sending_windows")
  fromIdentity   Json?    @map("from_identity")
  compliance     Json?
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("workspace_settings")
}

model WorkspaceMember {
  id          String        @id @default(uuid()) @db.Uuid
  workspaceId String        @map("workspace_id") @db.Uuid
  userId      String        @map("user_id") @db.Uuid
  role        WorkspaceRole @default(STAFF)
  invitedAt   DateTime?     @map("invited_at") @db.Timestamptz(6)
  joinedAt    DateTime?     @map("joined_at") @db.Timestamptz(6)
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
  @@map("workspace_members")
}

// --- Leads domain (Phase D) ---

enum LeadSource {
  MANUAL
  IMPORT
  GOOGLE_MAPS
  WEBSITE
  DIRECTORY
}

enum LeadStatus {
  NEW
  ENRICHING
  SCORED
  READY
  IN_CAMPAIGN
  REPLIED
  WON
  LOST
  SUPPRESSED
}

enum ContactRole {
  FOUNDER
  CEO
  OWNER
  DIRECTOR
  MARKETING
  IT
  OPERATIONS
  OTHER
}

enum EmailStatus {
  UNKNOWN
  VALID
  INVALID
  RISKY
  CATCH_ALL
}

model Company {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  name        String
  website     String?
  domain      String?
  industry    String?
  sizeBand    String?   @map("size_band")
  country     String?
  city        String?
  techStack   Json?     @map("tech_stack")
  socials     Json?
  revenueBand String?   @map("revenue_band")
  raw         Json?
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contacts  Contact[]
  leads     Lead[]
  audits    WebsiteAudit[]

  @@index([workspaceId, domain])
  @@index([workspaceId, deletedAt])
  @@map("companies")
}

model Contact {
  id          String       @id @default(uuid()) @db.Uuid
  workspaceId String       @map("workspace_id") @db.Uuid
  companyId   String       @map("company_id") @db.Uuid
  name        String?
  title       String?
  roleType    ContactRole? @map("role_type")
  email       String?
  emailStatus EmailStatus  @default(UNKNOWN) @map("email_status")
  linkedinUrl String?      @map("linkedin_url")
  confidence  Int?
  raw         Json?
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?    @map("deleted_at") @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  leads     Lead[]

  @@index([workspaceId, companyId])
  @@index([workspaceId, email])
  @@map("contacts")
}

model Lead {
  id          String     @id @default(uuid()) @db.Uuid
  workspaceId String     @map("workspace_id") @db.Uuid
  companyId   String     @map("company_id") @db.Uuid
  contactId   String?    @map("contact_id") @db.Uuid
  source      LeadSource @default(MANUAL)
  sourceKey   String?    @map("source_key")
  status      LeadStatus @default(NEW)
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?  @map("deleted_at") @db.Timestamptz(6)

  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact   Contact?   @relation(fields: [contactId], references: [id], onDelete: SetNull)
  score     LeadScore?
  emails    EmailDraft[]

  @@unique([workspaceId, source, sourceKey])
  @@index([workspaceId, status])
  @@index([workspaceId, deletedAt])
  @@map("leads")
}

// Deterministic 0-100 lead score (M37). fit = ICP match, intent = opportunity
// (a worse website = more to sell). One current score per lead (upserted).
model LeadScore {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  leadId      String   @unique @map("lead_id") @db.Uuid
  score       Int
  fitScore    Int      @map("fit_score")
  intentScore Int      @map("intent_score")
  confidence  Int
  factors     Json?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lead      Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([workspaceId, score])
  @@map("lead_scores")
}

// Cached email verification result (M36). status uses EmailStatus.
// Without SMTP RCPT (port 25 often blocked), VALID means good syntax + live MX
// + not disposable/role — deliverability is inferred, not mailbox-confirmed.
model EmailVerification {
  id          String      @id @default(uuid()) @db.Uuid
  workspaceId String      @map("workspace_id") @db.Uuid
  emailHash   String      @map("email_hash")
  email       String
  status      EmailStatus @default(UNKNOWN)
  mxOk        Boolean     @default(false) @map("mx_ok")
  disposable  Boolean     @default(false)
  roleAccount Boolean     @default(false) @map("role_account")
  riskScore   Int         @map("risk_score")
  reason      String?
  checkedAt   DateTime    @default(now()) @map("checked_at") @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, emailHash])
  @@map("email_verifications")
}

enum AuditStatus {
  OK
  PARTIAL
  FAILED
}

// Result of analyzing a company's website — the evidence that powers
// audit-driven personalization. AI narrative summary added in M35.
model WebsiteAudit {
  id               String      @id @default(uuid()) @db.Uuid
  workspaceId      String      @map("workspace_id") @db.Uuid
  companyId        String      @map("company_id") @db.Uuid
  url              String
  status           AuditStatus @default(OK)
  https            Boolean     @default(false)
  sslValid         Boolean     @default(false) @map("ssl_valid")
  statusCode       Int?        @map("status_code")
  responseTimeMs   Int?        @map("response_time_ms")
  title            String?
  metaDescription  String?     @map("meta_description")
  h1Count          Int?        @map("h1_count")
  mobileFriendly   Boolean     @default(false) @map("mobile_friendly")
  hasContactForm   Boolean     @default(false) @map("has_contact_form")
  hasCta           Boolean     @default(false) @map("has_cta")
  cms              String?
  techStack        Json?       @map("tech_stack")
  findings         Json?
  performanceScore Int?        @map("performance_score")
  aiSummary        String?     @map("ai_summary")
  error            String?
  createdAt        DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([workspaceId, companyId])
  @@map("website_audits")
}

// AI-personalized cold email generated for a lead (M39). Grounded in the lead's
// website audit + score. Provider-agnostic: records which provider/model/tier
// produced it plus token/cost, so output is auditable across Gemini/Claude.
model EmailDraft {
  id           String   @id @default(uuid()) @db.Uuid
  workspaceId  String   @map("workspace_id") @db.Uuid
  leadId       String   @map("lead_id") @db.Uuid
  subject      String
  body         String   @db.Text
  provider     String
  model        String
  tier         String
  inputTokens  Int      @default(0) @map("input_tokens")
  outputTokens Int      @default(0) @map("output_tokens")
  costUsd      Decimal  @default(0) @map("cost_usd") @db.Decimal(12, 6)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lead      Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([workspaceId, leadId])
  @@map("email_drafts")
}
