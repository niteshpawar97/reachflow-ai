// ReachFlow AI — Prisma schema.
// Conventions (see docs/05-database.md): uuid PKs, snake_case columns/tables via @map,
// timestamptz timestamps, soft-delete via deleted_at, workspace_id tenancy seam on domain tables.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Global platform role (across the whole app).
enum UserRole {
  ADMIN
  STAFF
  CLIENT
}

// Role within a specific workspace (tenant).
enum WorkspaceRole {
  ADMIN
  STAFF
  CLIENT
}

model User {
  id              String    @id @default(uuid()) @db.Uuid
  email           String    @unique
  passwordHash    String?   @map("password_hash")
  name            String?
  avatarUrl       String?   @map("avatar_url")
  emailVerifiedAt DateTime? @map("email_verified_at") @db.Timestamptz(6)
  roleGlobal      UserRole  @default(CLIENT) @map("role_global")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz(6)

  ownedWorkspaces Workspace[]       @relation("WorkspaceOwner")
  memberships     WorkspaceMember[]
  sessions        Session[]

  @@index([deletedAt])
  @@map("users")
}

// Refresh-token sessions. The raw refresh token is never stored — only its hash.
// Rotation: on refresh the current session is revoked and a new one created.
model Session {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  refreshTokenHash String    @unique @map("refresh_token_hash")
  userAgent        String?   @map("user_agent")
  ip               String?
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Workspace {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  slug        String    @unique
  ownerUserId String    @map("owner_user_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  owner              User                @relation("WorkspaceOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  members            WorkspaceMember[]
  settings           WorkspaceSettings?
  companies          Company[]
  contacts           Contact[]
  leads              Lead[]
  campaigns          Campaign[]
  campaignSteps      CampaignStep[]
  campaignLeads      CampaignLead[]
  websiteAudits      WebsiteAudit[]
  leadScores         LeadScore[]
  emailVerifications EmailVerification[]
  emailDrafts        EmailDraft[]
  mailboxes          Mailbox[]
  messages           Message[]
  suppressions       Suppression[]
  deals              Deal[]
  dealActivities     DealActivity[]

  @@index([ownerUserId])
  @@index([deletedAt])
  @@map("workspaces")
}

// 1:1 settings for a workspace. JSONB blobs hold evolving config so we don't
// churn the schema (sending windows, from-identity, compliance identity).
model WorkspaceSettings {
  id             String   @id @default(uuid()) @db.Uuid
  workspaceId    String   @unique @map("workspace_id") @db.Uuid
  timezone       String   @default("UTC")
  sendingWindows Json?    @map("sending_windows")
  fromIdentity   Json?    @map("from_identity")
  compliance     Json?
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("workspace_settings")
}

model WorkspaceMember {
  id          String        @id @default(uuid()) @db.Uuid
  workspaceId String        @map("workspace_id") @db.Uuid
  userId      String        @map("user_id") @db.Uuid
  role        WorkspaceRole @default(STAFF)
  invitedAt   DateTime?     @map("invited_at") @db.Timestamptz(6)
  joinedAt    DateTime?     @map("joined_at") @db.Timestamptz(6)
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
  @@map("workspace_members")
}

// --- Leads domain (Phase D) ---

enum LeadSource {
  MANUAL
  IMPORT
  GOOGLE_MAPS
  WEBSITE
  DIRECTORY
}

enum LeadStatus {
  NEW
  ENRICHING
  SCORED
  READY
  IN_CAMPAIGN
  REPLIED
  WON
  LOST
  SUPPRESSED
}

enum ContactRole {
  FOUNDER
  CEO
  OWNER
  DIRECTOR
  MARKETING
  IT
  OPERATIONS
  OTHER
}

enum EmailStatus {
  UNKNOWN
  VALID
  INVALID
  RISKY
  CATCH_ALL
}

model Company {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  name        String
  website     String?
  domain      String?
  industry    String?
  sizeBand    String?   @map("size_band")
  country     String?
  city        String?
  techStack   Json?     @map("tech_stack")
  socials     Json?
  revenueBand String?   @map("revenue_band")
  raw         Json?
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contacts  Contact[]
  leads     Lead[]
  audits    WebsiteAudit[]

  @@index([workspaceId, domain])
  @@index([workspaceId, deletedAt])
  @@map("companies")
}

model Contact {
  id          String       @id @default(uuid()) @db.Uuid
  workspaceId String       @map("workspace_id") @db.Uuid
  companyId   String       @map("company_id") @db.Uuid
  name        String?
  title       String?
  roleType    ContactRole? @map("role_type")
  email       String?
  emailStatus EmailStatus  @default(UNKNOWN) @map("email_status")
  linkedinUrl String?      @map("linkedin_url")
  confidence  Int?
  raw         Json?
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?    @map("deleted_at") @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  leads     Lead[]

  @@index([workspaceId, companyId])
  @@index([workspaceId, email])
  @@map("contacts")
}

model Lead {
  id          String     @id @default(uuid()) @db.Uuid
  workspaceId String     @map("workspace_id") @db.Uuid
  companyId   String     @map("company_id") @db.Uuid
  contactId   String?    @map("contact_id") @db.Uuid
  source      LeadSource @default(MANUAL)
  sourceKey   String?    @map("source_key")
  status      LeadStatus @default(NEW)
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?  @map("deleted_at") @db.Timestamptz(6)

  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact       Contact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)
  score         LeadScore?
  emails        EmailDraft[]
  campaignLeads CampaignLead[]
  deals         Deal[]

  @@unique([workspaceId, source, sourceKey])
  @@index([workspaceId, status])
  @@index([workspaceId, deletedAt])
  @@map("leads")
}

// Deterministic 0-100 lead score (M37). fit = ICP match, intent = opportunity
// (a worse website = more to sell). One current score per lead (upserted).
model LeadScore {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  leadId      String   @unique @map("lead_id") @db.Uuid
  score       Int
  fitScore    Int      @map("fit_score")
  intentScore Int      @map("intent_score")
  confidence  Int
  factors     Json?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lead      Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([workspaceId, score])
  @@map("lead_scores")
}

// Cached email verification result (M36). status uses EmailStatus.
// Without SMTP RCPT (port 25 often blocked), VALID means good syntax + live MX
// + not disposable/role — deliverability is inferred, not mailbox-confirmed.
model EmailVerification {
  id          String      @id @default(uuid()) @db.Uuid
  workspaceId String      @map("workspace_id") @db.Uuid
  emailHash   String      @map("email_hash")
  email       String
  status      EmailStatus @default(UNKNOWN)
  mxOk        Boolean     @default(false) @map("mx_ok")
  disposable  Boolean     @default(false)
  roleAccount Boolean     @default(false) @map("role_account")
  riskScore   Int         @map("risk_score")
  reason      String?
  checkedAt   DateTime    @default(now()) @map("checked_at") @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, emailHash])
  @@map("email_verifications")
}

enum AuditStatus {
  OK
  PARTIAL
  FAILED
}

enum EmailDraftStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EmailDraftKind {
  INITIAL
  FOLLOWUP
  VARIANT
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  STOPPED
  COMPLETED
}

enum CampaignStepMode {
  AI
  FIXED
}

enum CampaignStepTrigger {
  SEND
  NO_REPLY
  OPENED
  CLICKED
  REPLIED
}

enum CampaignLeadStatus {
  PENDING
  QUEUED
  SENDING
  SENT
  OPENED
  REPLIED
  BOUNCED
  SKIPPED
  STOPPED
}

// Result of analyzing a company's website — the evidence that powers
// audit-driven personalization. AI narrative summary added in M35.
model WebsiteAudit {
  id               String      @id @default(uuid()) @db.Uuid
  workspaceId      String      @map("workspace_id") @db.Uuid
  companyId        String      @map("company_id") @db.Uuid
  url              String
  status           AuditStatus @default(OK)
  https            Boolean     @default(false)
  sslValid         Boolean     @default(false) @map("ssl_valid")
  statusCode       Int?        @map("status_code")
  responseTimeMs   Int?        @map("response_time_ms")
  title            String?
  metaDescription  String?     @map("meta_description")
  h1Count          Int?        @map("h1_count")
  mobileFriendly   Boolean     @default(false) @map("mobile_friendly")
  hasContactForm   Boolean     @default(false) @map("has_contact_form")
  hasCta           Boolean     @default(false) @map("has_cta")
  cms              String?
  techStack        Json?       @map("tech_stack")
  findings         Json?
  performanceScore Int?        @map("performance_score")
  aiSummary        String?     @map("ai_summary")
  error            String?
  createdAt        DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([workspaceId, companyId])
  @@map("website_audits")
}

// AI-personalized cold email generated for a lead (M39). Grounded in the lead's
// website audit + score. Provider-agnostic: records which provider/model/tier
// produced it plus token/cost, so output is auditable across Gemini/Claude.
model EmailDraft {
  id            String           @id @default(uuid()) @db.Uuid
  workspaceId   String           @map("workspace_id") @db.Uuid
  leadId        String           @map("lead_id") @db.Uuid
  status        EmailDraftStatus @default(PENDING)
  kind          EmailDraftKind   @default(INITIAL)
  variantLabel  String?          @map("variant_label")
  sequenceIndex Int              @default(0) @map("sequence_index")
  subject       String
  body          String           @db.Text
  provider      String
  model         String
  tier          String
  inputTokens   Int              @default(0) @map("input_tokens")
  outputTokens  Int              @default(0) @map("output_tokens")
  costUsd       Decimal          @default(0) @map("cost_usd") @db.Decimal(12, 6)
  createdAt     DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  reviewedAt    DateTime?        @map("reviewed_at") @db.Timestamptz(6)
  deletedAt     DateTime?        @map("deleted_at") @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lead      Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([workspaceId, leadId])
  @@map("email_drafts")
}

// Campaign builder core (M44). A campaign is a sequenced outreach container
// with a workspace-scoped offer, schedule, mailbox pool, and daily cap.
model Campaign {
  id          String         @id @default(uuid()) @db.Uuid
  workspaceId String         @map("workspace_id") @db.Uuid
  name        String
  offer       String         @db.Text
  status      CampaignStatus @default(DRAFT)
  timezone    String         @default("UTC")
  schedule    Json?          @map("schedule")
  mailboxPool Json?          @map("mailbox_pool")
  dailyCap    Int            @default(0) @map("daily_cap")
  launchedAt  DateTime?      @map("launched_at") @db.Timestamptz(6)
  pausedAt    DateTime?      @map("paused_at") @db.Timestamptz(6)
  stoppedAt   DateTime?      @map("stopped_at") @db.Timestamptz(6)
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?      @map("deleted_at") @db.Timestamptz(6)

  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  steps     CampaignStep[]
  leads     CampaignLead[]

  @@index([workspaceId, status])
  @@index([workspaceId, deletedAt])
  @@map("campaigns")
}

// Sequence step within a campaign. Supports both AI-generated and fixed copy,
// plus trigger + delay so later scheduler/follow-up milestones can reuse it.
model CampaignStep {
  id           String              @id @default(uuid()) @db.Uuid
  workspaceId  String              @map("workspace_id") @db.Uuid
  campaignId   String              @map("campaign_id") @db.Uuid
  position     Int
  mode         CampaignStepMode    @default(AI)
  trigger      CampaignStepTrigger @default(SEND)
  delayMinutes Int                 @default(0) @map("delay_minutes")
  subject      String?
  body         String?             @db.Text
  aiPrompt     String?             @map("ai_prompt") @db.Text
  createdAt    DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaign  Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, position])
  @@index([workspaceId, campaignId])
  @@map("campaign_steps")
}

// Lead-to-campaign assignment and execution state. This is what the scheduler
// and sender advance as the sequence runs.
model CampaignLead {
  id            String             @id @default(uuid()) @db.Uuid
  workspaceId   String             @map("workspace_id") @db.Uuid
  campaignId    String             @map("campaign_id") @db.Uuid
  leadId        String             @map("lead_id") @db.Uuid
  status        CampaignLeadStatus @default(PENDING)
  currentStep   Int                @default(0) @map("current_step")
  nextSendAt    DateTime?          @map("next_send_at") @db.Timestamptz(6)
  lastSentAt    DateTime?          @map("last_sent_at") @db.Timestamptz(6)
  lastEventAt   DateTime?          @map("last_event_at") @db.Timestamptz(6)
  trackingToken String?            @unique @map("tracking_token")
  openedAt      DateTime?          @map("opened_at") @db.Timestamptz(6)
  clickedAt     DateTime?          @map("clicked_at") @db.Timestamptz(6)
  openCount     Int                @default(0) @map("open_count")
  clickCount    Int                @default(0) @map("click_count")
  queuedAt      DateTime?          @map("queued_at") @db.Timestamptz(6)
  queuedJobKey  String?            @unique @map("queued_job_key")
  stopReason    String?            @map("stop_reason")
  createdAt     DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaign  Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  lead      Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@unique([campaignId, leadId])
  @@index([workspaceId, campaignId, status])
  @@index([workspaceId, nextSendAt])
  @@index([workspaceId, trackingToken])
  @@map("campaign_leads")
}

// --- Mailboxes (Phase C / M17) ---

enum MailboxProvider {
  SMTP
  GMAIL
  M365
}

enum MailboxStatus {
  ACTIVE
  DISCONNECTED
  ERROR
  PAUSED
}

// A sending identity. SMTP mailboxes are usable today (host/port/user/pass);
// GMAIL/M365 arrive with OAuth. All secrets (SMTP password or OAuth tokens) are
// stored AES-256-GCM encrypted in `secretCiphertext` and NEVER returned by the API.
model Mailbox {
  id               String          @id @default(uuid()) @db.Uuid
  workspaceId      String          @map("workspace_id") @db.Uuid
  provider         MailboxProvider @default(SMTP)
  email            String
  displayName      String?         @map("display_name")
  status           MailboxStatus   @default(ACTIVE)
  smtpHost         String?         @map("smtp_host")
  smtpPort         Int?            @map("smtp_port")
  smtpSecure       Boolean         @default(true) @map("smtp_secure")
  smtpUsername     String?         @map("smtp_username")
  secretCiphertext String?         @map("secret_ciphertext") @db.Text
  dailyLimit       Int             @default(50) @map("daily_limit")
  sentToday        Int             @default(0) @map("sent_today")
  warmupEnabled    Boolean         @default(false) @map("warmup_enabled")
  lastError        String?         @map("last_error")
  // IMAP (reply sync, M55) — most providers (Zoho/Gmail/cPanel) reuse the SMTP
  // password, so we read the same secretCiphertext; only host/port/user differ.
  imapHost         String?         @map("imap_host")
  imapPort         Int?            @map("imap_port")
  imapSecure       Boolean         @default(true) @map("imap_secure")
  imapUsername     String?         @map("imap_username")
  imapLastUid      Int             @default(0) @map("imap_last_uid")
  imapLastSyncAt   DateTime?       @map("imap_last_sync_at") @db.Timestamptz(6)
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime?       @map("deleted_at") @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@unique([workspaceId, email])
  @@index([workspaceId, status])
  @@map("mailboxes")
}

// --- Inbox / reply sync (M55-58) ---

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum ReplyClassification {
  UNCLASSIFIED
  INTERESTED
  NOT_INTERESTED
  MEETING_REQUEST
  PRICING_QUESTION
  REFERRAL
  OUT_OF_OFFICE
  UNSUBSCRIBE_REQUEST
  BOUNCE
  SPAM
  OTHER
}

// One row per email seen on a mailbox (sent or received), synced incrementally
// via IMAP UID (imapUid > mailbox.imapLastUid). Linked to the CampaignLead it
// replies to via campaignLeadId when a match is found (In-Reply-To / References
// / tracking token in body / subject+participant heuristic).
model Message {
  id                       String              @id @default(uuid()) @db.Uuid
  workspaceId              String              @map("workspace_id") @db.Uuid
  mailboxId                String              @map("mailbox_id") @db.Uuid
  campaignLeadId           String?             @map("campaign_lead_id") @db.Uuid
  direction                MessageDirection    @default(INBOUND)
  fromAddress              String              @map("from_address")
  toAddress                String              @map("to_address")
  subject                  String?
  snippet                  String?
  bodyText                 String?             @map("body_text") @db.Text
  messageIdHeader          String?             @map("message_id_header")
  inReplyTo                String?             @map("in_reply_to")
  imapUid                  Int?                @map("imap_uid")
  receivedAt               DateTime            @map("received_at") @db.Timestamptz(6)
  classification           ReplyClassification @default(UNCLASSIFIED)
  classificationConfidence Int?                @map("classification_confidence")
  classificationSummary    String?             @map("classification_summary") @db.Text
  isRead                   Boolean             @default(false) @map("is_read")
  createdAt                DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  mailbox      Mailbox       @relation(fields: [mailboxId], references: [id], onDelete: Cascade)
  campaignLead CampaignLead? @relation(fields: [campaignLeadId], references: [id], onDelete: SetNull)

  @@unique([mailboxId, imapUid])
  @@index([workspaceId, campaignLeadId])
  @@index([workspaceId, direction, receivedAt])
  @@map("messages")
}

// --- Compliance: suppression list (unsubscribe / bounce / manual) ---

enum SuppressionReason {
  UNSUBSCRIBED
  BOUNCED
  COMPLAINED
  MANUAL
}

// Emails that must never be sent to again. Checked before every campaign send.
model Suppression {
  id          String            @id @default(uuid()) @db.Uuid
  workspaceId String            @map("workspace_id") @db.Uuid
  email       String
  reason      SuppressionReason
  note        String?
  createdAt   DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, email])
  @@map("suppressions")
}

// --- CRM (M59-62) ---

enum DealStage {
  NEW
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum DealActivityType {
  EMAIL
  REPLY
  CALL
  NOTE
  MEETING
  STAGE_CHANGE
}

model Deal {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  leadId      String    @map("lead_id") @db.Uuid
  title       String
  stage       DealStage @default(NEW)
  value       Decimal?  @db.Decimal(12, 2)
  currency    String    @default("USD")
  closedAt    DateTime? @map("closed_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspace  Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lead       Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  activities DealActivity[]

  @@index([workspaceId, stage])
  @@map("deals")
}

model DealActivity {
  id          String           @id @default(uuid()) @db.Uuid
  workspaceId String           @map("workspace_id") @db.Uuid
  dealId      String           @map("deal_id") @db.Uuid
  type        DealActivityType
  body        String?          @db.Text
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  deal      Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([workspaceId, dealId])
  @@map("deal_activities")
}
